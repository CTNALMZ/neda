<Window x:Class="NEDA.EngineIntegration.Controllers.NEDAControlPanel.NEDAControlPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NEDA Control Panel" Height="900" Width="1400">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sol Panel: Kontroller -->
        <StackPanel Grid.Column="0" Margin="10">
            <TextBlock Text="NEDA Control Panel" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
            <Button Content="Plan Game" Height="40" Margin="0,5" Click="BtnPlanGame_Click"/>
            <Button Content="Add NPC" Height="40" Margin="0,5" Click="BtnAddNPC_Click"/>
            <Button Content="Generate Blueprint" Height="40" Margin="0,5" Click="BtnGenerateBlueprint_Click"/>
            <Button Content="Render Scene" Height="40" Margin="0,5" Click="BtnRenderScene_Click"/>
            <Button Content="BuildRun" Height="40" Margin="0,5" Click="BtnBuildRun_Click"/>
            <Button Content="Trigger Cutscene" Height="40" Margin="0,5" Click="BtnCutscene_Click"/>
        </StackPanel>

        <!-- Sağ Panel: 3D Preview -->
        <Viewport3D Grid.Column="1" Name="MainViewport" ClipToBounds="True">
            <Viewport3D.Camera>
                <PerspectiveCamera Position="0,200,500" LookDirection="0,-100,-500" UpDirection="0,1,0" FieldOfView="60"/>
            </Viewport3D.Camera>

            <!-- Örnek ışık -->
            <ModelVisual3D>
                <ModelVisual3D.Content>
                    <DirectionalLight Color="White" Direction="-1,-1,-1"/>
                </ModelVisual3D.Content>
            </ModelVisual3D>

            <!-- Örnek model: Küp -->
            <ModelVisual3D>
                <ModelVisual3D.Content>
                    <GeometryModel3D>
                        <GeometryModel3D.Geometry>
                            <MeshGeometry3D Positions="-50,-50,50 50,-50,50 50,50,50 -50,50,50 -50,-50,-50 50,-50,-50 50,50,-50 -50,50,-50"
                                            TriangleIndices="0 1 2 0 2 3 1 5 6 1 6 2 5 4 7 5 7 6 4 0 3 4 3 7 3 2 6 3 6 7 4 5 1 4 1 0"/>
                        </GeometryModel3D.Geometry>
                        <GeometryModel3D.Material>
                            <DiffuseMaterial Brush="LightBlue"/>
                        </GeometryModel3D.Material>
                    </GeometryModel3D>
                </ModelVisual3D.Content>
            </ModelVisual3D>
        </Viewport3D>
    </Grid>
</Window>
